# 企业微信配置示例

# 企业ID - 在「我的企业」页面获取
WECOM_CORP_ID=ww4e741231e8441d9d

# 应用ID - 在应用详情页获取
WECOM_AGENT_ID=1000002

# 应用Secret - 在应用详情页获取
WECOM_SECRET=6DnbiWo7eZGR8IIDyQWUmb41MPCVUYdFmOJDeLgvfZw

# 接收消息的Token（可选，用于消息加解密）
WECOM_TOKEN=openclaw123

# 接收消息的EncodingAESKey（可选）
WECOM_ENCODING_AES_KEY=fO3wWVx1uryt9LzoNLX7ynUwox2AcugLqPytGeqOYd6

# 服务器端口
PORT=3456

# 管理员企业微信ID（可选）
ADMIN_USER_ID=Notdog

# OpenClaw 配置
# OpenClaw Gateway 地址（默认: http://127.0.0.1:18789）
OPENCLAW_URL=http://127.0.0.1:18789

# OpenClaw Gateway Token（在 openclaw.json 的 gateway.auth.token 中获取）
OPENCLAW_TOKEN=3a62987190508b4d516dc1dafcc857e650c64f095d25644d

# OpenClaw Agent ID（默认: main）
OPENCLAW_AGENT_ID=main
