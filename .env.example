# 企业微信配置示例

# 企业ID - 在「我的企业」页面获取
WECOM_CORP_ID=wwxxxxxxxxxxxxxxxx

# 应用ID - 在应用详情页获取
WECOM_AGENT_ID=1000002

# 应用Secret - 在应用详情页获取
WECOM_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 接收消息的Token（可选，用于消息加解密）
WECOM_TOKEN=your_random_token

# 接收消息的EncodingAESKey（可选）
WECOM_ENCODING_AES_KEY=your_random_aes_key

# 服务器端口
PORT=3000

# 管理员企业微信ID（可选）
ADMIN_USER_ID=ZhangSan
